{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "clue-forge-web",
	"pages_build_output_dir": "./dist",
	"compatibility_date": "2026-07-07",
	"observability": {
		"enabled": true,
		"logs": {
			"head_sampling_rate": 1
		},
		"traces": {
			"enabled": true,
			"head_sampling_rate": 0.01
		}
	},
	"services": [
		{
			"binding": "API",
			"service": "clue-forge-api"
		}
	]
}
